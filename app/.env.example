# Porta da aplicacao Auto.io
PORT=3000

# Interface de escuta. 127.0.0.1 mantem a base acessivel so nesta maquina.
# Use 0.0.0.0 apenas se souber que quer expor na rede local.
HOST=127.0.0.1

# LM Studio normalmente usa essa URL quando o servidor local esta ligado.
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Pode deixar local-model. Se der erro de modelo, coloque aqui o nome exato do modelo carregado no LM Studio.
LMSTUDIO_MODEL=

# Tempo maximo de espera pela IA local. Passou disso, entra o fallback por regras.
LMSTUDIO_TIMEOUT_MS=60000
SHEETS_TIMEOUT_MS=10000

# Senha do painel do vendedor. Troque em apresentacao real.
SELLER_PASSWORD=12345

# Chave usada para assinar o cookie de sessao do vendedor.
# Se ficar vazia, o servidor gera uma nova a cada restart (as sessoes caem).
# Gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Opcional: URL do Apps Script para enviar registros ao Google Sheets (precisa ser https)
SHEETS_WEBHOOK_URL=
